{
  "name": "employee-management-mern",
  "version": "1.0.0",
  "private": true,
  "description": "MERN Employee Management System — root workspace",
  "scripts": {
    "dev:frontend": "npm run dev --prefix frontend",
    "dev:backend": "npm run dev --prefix backend",
    "dev": "npm-run-all --parallel dev:frontend dev:backend",
    "build": "npm run build --prefix frontend",
    "lint:frontend": "npm run lint --prefix frontend",
    "lint:backend": "npm run lint --prefix backend",
    "lint": "npm-run-all lint:frontend lint:backend",
    "format": "npm-run-all format:frontend format:backend",
    "format:frontend": "npm run format --prefix frontend",
    "format:backend": "npm run format --prefix backend",
    "audit:frontend": "npm audit --prefix frontend",
    "audit:backend": "npm audit --prefix backend",
    "audit": "npm-run-all audit:frontend audit:backend",
    "prepare": "husky"
  },
  "devDependencies": {  
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.2",
    "npm-run-all": "^4.1.5"
  },
  "lint-staged": {
    "frontend/src/**/*.{js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "backend/src/**/*.js": [
      "eslint --fix",
      "prettier --write"
    ]
  }
}
